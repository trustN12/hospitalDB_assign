@model HospitalDb.Models.Patient

@{
    ViewData["Title"] = "Patient Details";
}

<div class="container mt-5">

    <div class="card shadow-lg border-0">

        <!-- Header -->
        <div class="card-header text-white"
             style="background: linear-gradient(45deg,#0d6efd,#6610f2);">

            <div class="d-flex justify-content-between align-items-center">

                <h3 class="mb-0">
                    <i class="bi bi-person-vcard"></i> Patient Profile
                </h3>

                <span class="badge bg-light text-dark fs-6">
                    ID : @Model.Pid
                </span>

            </div>

        </div>


        <div class="card-body">

            <div class="row">

                <!-- Avatar -->
                <div class="col-md-4 text-center">

                    <div class="mb-3">
                        <i class="bi bi-person-circle text-primary"
                           style="font-size:120px;"></i>
                    </div>

                    <h4 class="fw-bold">
                        @Model.Fname @Model.Lname
                    </h4>

                    @if(Model.Gender == "Male")
                    {
                        <span class="badge bg-primary fs-6">Male</span>
                    }
                    else
                    {
                        <span class="badge bg-danger fs-6">Female</span>
                    }

                </div>


                <!-- Patient Information -->
                <div class="col-md-8">

                    <h5 class="text-secondary mb-3">
                        <i class="bi bi-info-circle"></i> Patient Information
                    </h5>

                    <table class="table table-borderless">

                        <tr>
                            <th width="200">First Name</th>
                            <td>@Model.Fname</td>
                        </tr>

                        <tr>
                            <th>Last Name</th>
                            <td>@Model.Lname</td>
                        </tr>

                        <tr>
                            <th>Gender</th>
                            <td>@Model.Gender</td>
                        </tr>

                    </table>


                    <hr>


                    <h5 class="text-secondary mb-3">
                        <i class="bi bi-hospital"></i> Doctor Information
                    </h5>

                    <table class="table table-borderless">

                        <tr>
                            <th width="200">Doctor Name</th>
                            <td>
                                <i class="bi bi-person-badge text-success"></i>
                                @Model.DoctorName
                            </td>
                        </tr>

                        <tr>
                            <th>Specialisation</th>
                            <td>
                                <span class="badge bg-info text-dark">
                                    @Model.Specialisation
                                </span>
                            </td>
                        </tr>

                    </table>

                </div>

            </div>

        </div>


        <!-- Footer Buttons -->
        <div class="card-footer bg-light text-end">

            <a asp-action="Edit"
               asp-route-id="@Model?.Pid"
               class="btn btn-warning">

                <i class="bi bi-pencil-square"></i> Edit
            </a>

            <a asp-action="Delete"
               asp-route-id="@Model?.Pid"
               class="btn btn-danger">

                <i class="bi bi-trash"></i> Delete
            </a>

            <a asp-action="Index"
               class="btn btn-secondary">

                <i class="bi bi-arrow-left"></i> Back
            </a>

        </div>

    </div>

</div>