@model HospitalDb.Models.Patient

@{
    ViewData["Title"] = "Edit Patient";
}

<div class="container mt-5">

    <div class="card shadow-lg border-0">

        <!-- Header -->
        <div class="card-header bg-warning text-dark d-flex justify-content-between align-items-center">
            <h3 class="mb-0">
                <i class="bi bi-pencil-square"></i> Edit Patient
            </h3>

            <span class="badge bg-dark">
                Patient ID : @Model.Pid
            </span>
        </div>

        <div class="card-body">

            <form asp-action="Edit" method="post">

                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <input type="hidden" asp-for="Pid" />

                <div class="row">

                    <!-- First Name -->
                    <div class="col-md-6 mb-3">
                        <label asp-for="Fname" class="form-label fw-bold"></label>
                        <input asp-for="Fname" class="form-control" placeholder="Enter First Name"/>
                        <span asp-validation-for="Fname" class="text-danger"></span>
                    </div>

                    <!-- Last Name -->
                    <div class="col-md-6 mb-3">
                        <label asp-for="Lname" class="form-label fw-bold"></label>
                        <input asp-for="Lname" class="form-control" placeholder="Enter Last Name"/>
                        <span asp-validation-for="Lname" class="text-danger"></span>
                    </div>

                    <!-- Gender -->
                    <div class="col-md-6 mb-3">
                        <label asp-for="Gender" class="form-label fw-bold"></label>

                        <select asp-for="Gender" class="form-select">
                            <option value="">-- Select Gender --</option>
                            <option>Male</option>
                            <option>Female</option>
                            <option>Other</option>
                        </select>

                        <span asp-validation-for="Gender" class="text-danger"></span>
                    </div>

                    <!-- Doctor -->
                    <div class="col-md-6 mb-3">
                        <label asp-for="Did" class="form-label fw-bold">Assign Doctor</label>

                        <select asp-for="Did" class="form-select" asp-items="@ViewBag.Did"></select>

                        <span asp-validation-for="Did" class="text-danger"></span>
                    </div>

                </div>

                <!-- Buttons -->
                <div class="mt-4">

                    <button type="submit" class="btn btn-success px-4 shadow-sm">
                        <i class="bi bi-save"></i> Save Changes
                    </button>

                    <a asp-action="Index" class="btn btn-secondary ms-2">
                        <i class="bi bi-arrow-left"></i> Back
                    </a>

                </div>

            </form>

        </div>

    </div>

</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}